local SonicAll = Instance.new("TextButton")
SonicAll.Parent = Main
SonicAll.BorderSizePixel = 0
SonicAll.BackgroundColor3 = Color3.fromRGB(255,255,255)
SonicAll.Size = UDim2.new(0,100,0,70)
SonicAll.Position = UDim2.new(0,132,0,108)
SonicAll.Text = "SONIC all"

SonicAll.MouseButton1Click:Connect(function()

local Players = game:GetService("Players")

local function applyEffect(player)
	local function onCharacter(character)
		local root = character:WaitForChild("HumanoidRootPart",5)
		if not root then return end

		for _,v in pairs(character:GetDescendants()) do
			if v:IsA("BasePart") or v:IsA("Decal") then
				v.Transparency = 1
			end
		end

		local smoke = Instance.new("Smoke")
		smoke.Parent = root
		smoke.Color = Color3.new(0.9,0.9,0.9)
		smoke.Opacity = 0.3
		smoke.Size = 0.5
		smoke.RiseVelocity = 3
		smoke.Enabled = true

		local billboard = Instance.new("BillboardGui")
		billboard.Parent = root
		billboard.Size = UDim2.new(8,0,15,0)
		billboard.StudsOffset = Vector3.new(0,3,0)
		billboard.AlwaysOnTop = true

		local image = Instance.new("ImageLabel")
		image.Parent = billboard
		image.Size = UDim2.new(1,0,1,0)
		image.BackgroundTransparency = 1
		image.ScaleType = Enum.ScaleType.Stretch

		local ids = {138571060500318}

		task.spawn(function()
			while image.Parent do
				for _,id in ipairs(ids) do
					image.Image = "rbxassetid://"..id
					task.wait(0.04)
				end
			end
		end)
	end

	if player.Character then
		onCharacter(player.Character)
	end

	player.CharacterAdded:Connect(onCharacter)
end

for _,player in pairs(Players:GetPlayers()) do
	applyEffect(player)
end

Players.PlayerAdded:Connect(applyEffect)

end)

local FireAll = Instance.new("TextButton")
FireAll.Parent = Main
FireAll.BorderSizePixel = 0
FireAll.BackgroundColor3 = Color3.fromRGB(255,255,255)
FireAll.Size = UDim2.new(0,100,0,72)
FireAll.Position = UDim2.new(0,356,0,108)
FireAll.Text = "fire all"

local fireEnabled = false
local fires = {}

FireAll.MouseButton1Click:Connect(function()
	fireEnabled = not fireEnabled

	for _,plr in pairs(Players:GetPlayers()) do
		if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
			if fireEnabled then
				if not fires[plr] then
					local fire = Instance.new("Fire")
					fire.Size = 10
					fire.Heat = 25
					fire.Color = Color3.fromRGB(255,85,0)
					fire.SecondaryColor = Color3.fromRGB(255,170,0)
					fire.Parent = plr.Character.HumanoidRootPart
					fires[plr] = fire
				end
			else
				if fires[plr] then
					fires[plr]:Destroy()
					fires[plr] = nil
				end
			end
		end
	end
end)

